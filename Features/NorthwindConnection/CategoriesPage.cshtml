@using AlloyTraining.Features.NorthwindConnection
@using AlloyTraining.Models.ViewModels;

@{
    Layout = "~/Views/Shared/Layouts/_LeftNavigation.cshtml";
}
<div class="row">
    <div class="col-12">
        <h2>Northwind Categories</h2>
        <ul>
            @foreach (KeyValuePair<string, string> category in Model.CurrentPage.CategoryLinks)
            {
                <li><a href="@category.Value">@category.Key</a></li>
            }
        </ul>
    </div>
</div>
