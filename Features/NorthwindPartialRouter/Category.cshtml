@using AlloyTraining.Features.NorthwindPartialRouter
@using AlloyTraining.Features.NorthwindPartialRouter.Entities;
@using AlloyTraining.Models.ViewModels
@model PageViewModel<CategoriesPage>
<div class="row">
    <div class="col-12">
        <h2>@Model.CurrentPage.NorthwindCategory.CategoryName</h2>
        <p class="text-muted">@Model.CurrentPage.NorthwindCategory.Description</p>
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Product Name</th>
                    <th>Unit Price</th>
                </tr>
            </thead>
            <tbody>
                @foreach (Product p in Model.CurrentPage.NorthwindCategory.Products)
                {
                    <tr>
                        <td>@p.ProductName</td>
                        <td>@p.UnitPrice.Value.ToString("$0.00")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
