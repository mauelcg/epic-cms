@using AlloyTraining.Business.ExtensionMethods
@using AlloyTraining.Models.Pages
@using AlloyTraining.Models.ViewModels
@using EPiServer.Cms.UI.AspNetIdentity;
@model IPageViewmodel<SitePageData>
@{
    Microsoft.AspNetCore.Mvc.Razor.HelperResult ItemTemplate(HtmlHelpers.MenuItem item)
    {
        <li class="nav-item">
            @Html.PageLink(item.Page, null, new { @class = "nav-link" + (item.Selected ? " active" : null) })
        </li>
        return new Microsoft.AspNetCore.Mvc.Razor.HelperResult(w => Task.CompletedTask);
    }
}
<div class="alloyMenu">
    <div class="navbar">
        <div class="navbar-inner">
            <div class="container">
                <a class="btn btn-navbar" data-toggle="collapse" data-target=".nav-collapse">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </a>
                <div class="nav-collapse">
                    <ul class="nav">
                        <li
                            class="@(Model.CurrentPage.ContentLink.CompareToIgnoreWorkID(ContentReference.StartPage) ? "nav-item active"
                                                                                                                                                                                                : "nav-item")">
                            @Html.ContentLink(ContentReference.StartPage, routeValues: null, new { @class = "nav-link" })
                        </li>
                        @Html.MenuList(ContentReference.StartPage, ItemTemplate)
                        <li class="nav-item">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <span class="nav-link text-decoration-none link-dark">
                                    @Html.ContentLink(linkText: "Log Out", action: "Logout")
                                </span>
                            }
                            else
                            {
                                <a href="/auth/login?ReturnUrl=@Model.CurrentPage.PageLink.ExternalURLFromReference()"" class="nav-link">Log in</a>
                            }
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
